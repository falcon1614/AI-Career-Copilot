# PostgreSQL
POSTGRES_USER=copilot
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=copilot_db
DATABASE_URL=postgresql://copilot:your_secure_password_here@postgres:5432/copilot_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_from_aistudio_google_com

# Service URLs (internal Docker network)
AUTH_SERVICE_URL=http://auth-service:3001
RESUME_SERVICE_URL=http://resume-service:3002
INTERVIEW_SERVICE_URL=http://interview-service:3003
CODING_SERVICE_URL=http://coding-service:3004
GENAI_SERVICE_URL=http://genai-service:8001
ML_SERVICE_URL=http://ml-service:8002
